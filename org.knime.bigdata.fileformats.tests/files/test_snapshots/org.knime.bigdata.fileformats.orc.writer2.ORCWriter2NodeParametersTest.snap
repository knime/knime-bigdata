{
  "data" : {
    "model" : {
      "outputLocation" : {
        "file" : {
          "path" : {
            "fsCategory" : "LOCAL",
            "path" : "",
            "timeout" : 10000,
            "context" : {
              "fsToString" : "(LOCAL, )"
            }
          }
        },
        "createMissingFolders" : false,
        "mode" : "FILE"
      },
      "compression" : "NONE",
      "fileSize" : 1000000,
      "fileNamePrefix" : "part_",
      "chunkSize" : 1024,
      "mapping" : {
        "byNameSettings" : [ ],
        "byTypeSettings" : [ ]
      }
    }
  },
  "schema" : {
    "type" : "object",
    "properties" : {
      "model" : {
        "type" : "object",
        "properties" : {
          "chunkSize" : {
            "type" : "integer",
            "format" : "int32",
            "title" : "Within file stripe size (rows)",
            "description" : "Defines the maximum number of rows of a file stripe. For more details see the <a href=\"https://cwiki.apache.org/confluence/display/Hive/LanguageManual+ORC\">ORC documentation</a>.",
            "default" : 1024
          },
          "compression" : {
            "oneOf" : [ {
              "const" : "NONE",
              "title" : "None"
            }, {
              "const" : "ZLIB",
              "title" : "ZLIB"
            }, {
              "const" : "SNAPPY",
              "title" : "SNAPPY"
            }, {
              "const" : "LZO",
              "title" : "LZO"
            }, {
              "const" : "LZ4",
              "title" : "LZ4"
            } ],
            "title" : "File Compression",
            "description" : "The compression codec used to write the ORC file.",
            "default" : "NONE"
          },
          "fileNamePrefix" : {
            "type" : "string",
            "title" : "File name prefix",
            "description" : "The prefix to use for the file within the selected folder. A running index is appended starting with 0 e.g. part_00000.orc, part_00001.orc. This option is only available if the folder mode is selected.",
            "default" : "part_"
          },
          "fileSize" : {
            "type" : "integer",
            "format" : "int64",
            "title" : "Split data into files of size (rows)",
            "description" : "Splits up the input data into files with at most the given number of data rows. This option is only available if the folder mode is selected.",
            "default" : 1000000
          },
          "mapping" : {
            "type" : "object",
            "properties" : {
              "byNameSettings" : {
                "type" : "array",
                "items" : {
                  "type" : "object",
                  "properties" : {
                    "filterType" : {
                      "oneOf" : [ {
                        "const" : "MANUAL",
                        "title" : "Manual"
                      }, {
                        "const" : "REGEX",
                        "title" : "Regex"
                      } ],
                      "title" : "Column selection type",
                      "description" : "The option allows you to select how the column is matched.\n<ul>\n<li><b>Manual</b>: Use the exact name of the column</li>\n<li><b>Regex</b>: Allow regex expressions to select multiple columns</li>\n</ul>",
                      "default" : "MANUAL"
                    },
                    "fromColName" : {
                      "type" : "string",
                      "title" : "Column name",
                      "description" : "The column name or regex expression.",
                      "default" : ""
                    },
                    "fromColType" : {
                      "type" : "string",
                      "title" : "KNIME type",
                      "description" : "KNIME data type to map from."
                    },
                    "toColType" : {
                      "type" : "string",
                      "title" : "Mapping to",
                      "description" : "External data type to map to."
                    }
                  }
                },
                "title" : "Name",
                "description" : "Columns that match the given name (or regular expression) and KNIME type will be mapped to the specified external type.\n",
                "default" : [ ]
              },
              "byTypeSettings" : {
                "type" : "array",
                "items" : {
                  "type" : "object",
                  "properties" : {
                    "fromType" : {
                      "type" : "string",
                      "title" : "KNIME type",
                      "description" : "KNIME data type to map from."
                    },
                    "toType" : {
                      "type" : "string",
                      "title" : "Mapping to",
                      "description" : "External data type to map to."
                    }
                  }
                },
                "title" : "Type",
                "description" : "Columns that match the given KNIME type will be mapped to the specified external data type.",
                "default" : [ ]
              }
            },
            "default" : {
              "byNameSettings" : [ ],
              "byTypeSettings" : [ ]
            }
          },
          "outputLocation" : {
            "type" : "object",
            "properties" : {
              "createMissingFolders" : {
                "type" : "boolean",
                "title" : "Create missing folders",
                "description" : "If enabled, missing folders in the specified path will be created automatically.",
                "default" : false
              },
              "file" : {
                "type" : "object",
                "properties" : {
                  "path" : {
                    "type" : "object",
                    "default" : {
                      "fsCategory" : "LOCAL",
                      "path" : "",
                      "timeout" : 10000,
                      "context" : {
                        "fsToString" : "(LOCAL, )"
                      }
                    }
                  }
                },
                "title" : "Output location",
                "description" : "Select a file system and location where you want to store the file(s).",
                "default" : {
                  "path" : {
                    "fsCategory" : "LOCAL",
                    "path" : "",
                    "timeout" : 10000,
                    "context" : {
                      "fsToString" : "(LOCAL, )"
                    }
                  }
                }
              },
              "mode" : {
                "oneOf" : [ {
                  "const" : "FILE",
                  "title" : "File"
                }, {
                  "const" : "FOLDER",
                  "title" : "Folder"
                } ],
                "title" : "Mode",
                "description" : "Depending on the selected mode the node writes the input data into a single file or splits it up into several files of the defined size which are then stored in the specified folder.",
                "default" : "FILE"
              }
            },
            "default" : {
              "file" : {
                "path" : {
                  "fsCategory" : "LOCAL",
                  "path" : "",
                  "timeout" : 10000,
                  "context" : {
                    "fsToString" : "(LOCAL, )"
                  }
                }
              },
              "createMissingFolders" : false,
              "mode" : "FILE"
            }
          }
        }
      }
    }
  },
  "ui_schema" : {
    "elements" : [ {
      "label" : "Settings",
      "type" : "Section",
      "description" : "General settings regarding the output file location and storage configuration.",
      "elements" : [ {
        "type" : "Control",
        "scope" : "#/properties/model/properties/outputLocation/properties/mode",
        "options" : {
          "format" : "valueSwitch"
        }
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/outputLocation/properties/file",
        "options" : {
          "fileExtension" : "orc",
          "isLocal" : true,
          "isWriter" : true,
          "selectionMode" : "FILE",
          "spaceFSOptions" : {
            "mountId" : "Local space"
          },
          "format" : "fileChooser"
        },
        "providedOptions" : [ "selectionMode" ]
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/outputLocation/properties/createMissingFolders",
        "options" : {
          "format" : "checkbox"
        }
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/compression"
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/fileSize",
        "options" : {
          "validation" : {
            "max" : {
              "errorMessage" : "Value too large to process without risking precision loss (> 9007199254740991).",
              "parameters" : {
                "isExclusive" : false,
                "max" : 9.007199254740991E15
              }
            },
            "min" : {
              "errorMessage" : "The value must be at least 1.",
              "parameters" : {
                "isExclusive" : false,
                "min" : 1.0
              }
            }
          }
        },
        "rule" : {
          "effect" : "SHOW",
          "condition" : {
            "scope" : "#/properties/model/properties/outputLocation/properties/mode",
            "schema" : {
              "oneOf" : [ {
                "const" : "FOLDER"
              } ]
            }
          }
        }
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/fileNamePrefix",
        "rule" : {
          "effect" : "SHOW",
          "condition" : {
            "scope" : "#/properties/model/properties/outputLocation/properties/mode",
            "schema" : {
              "oneOf" : [ {
                "const" : "FOLDER"
              } ]
            }
          }
        }
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/chunkSize",
        "options" : {
          "validation" : {
            "max" : {
              "errorMessage" : "The value must not exceed 2147483647.",
              "parameters" : {
                "isExclusive" : false,
                "max" : 2.147483647E9
              }
            },
            "min" : {
              "errorMessage" : "The value must be at least 1.",
              "parameters" : {
                "isExclusive" : false,
                "min" : 1.0
              }
            }
          }
        }
      } ]
    }, {
      "label" : "Type Mapping",
      "type" : "SettingsSubPanelLayout",
      "elements" : [ {
        "label" : "Mapping by Name",
        "type" : "Section",
        "description" : "Define name-based mappings that apply to specific columns.",
        "elements" : [ {
          "type" : "Control",
          "scope" : "#/properties/model/properties/mapping/properties/byNameSettings",
          "options" : {
            "detail" : [ {
              "type" : "Control",
              "scope" : "#/properties/filterType",
              "options" : {
                "format" : "valueSwitch"
              }
            }, {
              "type" : "Control",
              "scope" : "#/properties/fromColName"
            }, {
              "type" : "Control",
              "scope" : "#/properties/fromColType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues", "possibleValues" ]
            }, {
              "type" : "Control",
              "scope" : "#/properties/toColType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues" ]
            } ],
            "addButtonText" : "Add name",
            "arrayElementTitle" : "Column name"
          }
        } ]
      }, {
        "label" : "Mapping by Type",
        "type" : "Section",
        "description" : "Define type mappings that apply to all columns of the specified KNIME type. These mappings are applied after the mappings defined in the 'Mapping by Name' section.\n",
        "elements" : [ {
          "type" : "Control",
          "scope" : "#/properties/model/properties/mapping/properties/byTypeSettings",
          "options" : {
            "detail" : [ {
              "type" : "Control",
              "scope" : "#/properties/fromType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues", "possibleValues" ]
            }, {
              "type" : "Control",
              "scope" : "#/properties/toType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues" ]
            } ],
            "addButtonText" : "Add type",
            "arrayElementTitle" : "Type"
          }
        } ]
      } ]
    } ]
  },
  "persist" : {
    "type" : "object",
    "properties" : {
      "model" : {
        "type" : "object",
        "properties" : {
          "outputLocation" : {
            "type" : "object",
            "properties" : {
              "file" : {
                "configPaths" : [ [ "path" ] ]
              },
              "createMissingFolders" : {
                "configKey" : "create_missing_folders"
              },
              "mode" : {
                "configKey" : "filter_mode",
                "route" : [ "filter_mode" ]
              }
            },
            "configKey" : "file_chooser_settings",
            "route" : [ "settings" ]
          },
          "compression" : {
            "configPaths" : [ [ "file_compression" ] ],
            "route" : [ "settings" ]
          },
          "fileSize" : {
            "configKey" : "file_size",
            "route" : [ "settings" ]
          },
          "fileNamePrefix" : {
            "configKey" : "file_name_prefix",
            "route" : [ "settings" ]
          },
          "chunkSize" : {
            "configKey" : "within_file_chunk_size",
            "route" : [ "settings" ]
          },
          "mapping" : {
            "propertiesConfigPaths" : [ ],
            "propertiesDeprecatedConfigKeys" : [ {
              "deprecated" : [ [ "name_to_type_mapping_rules", "type_to_type_mapping_rules" ] ]
            } ],
            "configKey" : "input_type_mapping",
            "route" : [ "type_mapping" ]
          }
        }
      }
    }
  },
