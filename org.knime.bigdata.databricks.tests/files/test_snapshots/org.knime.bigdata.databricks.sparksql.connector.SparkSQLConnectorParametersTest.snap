  "initialUpdates" : [ {
    "scope" : "#/properties/model/properties/additionalSettings/properties/attributes",
    "providedOptionName" : "dynamicSettings",
    "values" : [ {
      "indices" : [ ],
      "value" : {
        "data" : null,
        "schema" : "{\"properties\":{\"knime-db-connection-idle-timeout\":{\"type\":\"integer\",\"title\":\"Automatically close idle connection timeout (seconds)\",\"description\":\"Time interval in seconds that a database connection can remain idle before it gets closed automatically.<br>A value of <strong>0</strong> disables the automatic closing of idle connections.<p><strong>Valid range:</strong> [0,)</p>\"},\"knime-db-connection-reconnect\":{\"type\":\"boolean\",\"title\":\"Automatically reconnect to database\",\"description\":\"Enables or disables the reconnection to the database if the connection is invalid. <br>Connection depending object will no longer exist after reconnection.\"},\"knime-db-connection-reconnect-timeout\":{\"type\":\"integer\",\"title\":\"Reconnect to database timeout (seconds)\",\"description\":\"Time interval in seconds to wait before canceling the reconnection to the database.<br>A value of <strong>0</strong> inidcates the standard connection timeout.<p><strong>Valid range:</strong> [0,)</p>\"},\"knime-db-connection-restore\":{\"type\":\"boolean\",\"title\":\"Restore database connection\",\"description\":\"Enables or disables the restoration of the database connection when an executed connector node is loaded.\"},\"knime-db-connection-validation_query\":{\"type\":\"string\",\"title\":\"Validation query\",\"description\":\"The query to be executed for validating that a connection is ready for use.<br>If no query is specified KNIME calls the Connection.isValid() method to validate the connection.<br>Only errors are checked, no result is required.\"},\"knime-db-dialect-sql-identifier-delimiting-onlyspaces\":{\"type\":\"boolean\",\"title\":\"Delimit only identifier with spaces\",\"description\":\"If selected only identifiers e.g. columns or table names with spaces are delimited.\"},\"knime-db-dialect-sql-delimiter-identifier-closing\":{\"type\":\"string\",\"title\":\"Identifier delimiter (closing)\"},\"knime-db-dialect-sql-delimiter-identifier-opening\":{\"type\":\"string\",\"title\":\"Identifier delimiter (opening)\"},\"knime-db-dialect-sql-identifier-replace-character-non_word-replacement\":{\"type\":\"string\",\"title\":\"Identifier non-word character replacement\",\"description\":\"The replacement for non-word characters in identifiers when their replacement is enabled. An empty value results in the removal of non-word characters.\"},\"knime-db-dialect-sql-identifier-replace-character-non_word-enabled\":{\"type\":\"boolean\",\"title\":\"Replace non-word characters in identifiers\",\"description\":\"Whether to replace non-word characters in identifiers, e.g. table or column names. Non-word characters include all characters other than alphanumeric characters (a-z, A-Z, 0-9) and underscore (_).\"},\"knime-db-connection-logger-enabled\":{\"type\":\"boolean\",\"title\":\"Enable\",\"description\":\"Enables or disables logger for JDBC operations.\"},\"knime-db-connection-statement-cancellation-enabled\":{\"type\":\"boolean\",\"title\":\"Enable\",\"description\":\"Enables or disables JDBC statement cancellation attempts when node execution is canceled.\"},\"knime-db-connection-statement-cancellation-polling_period\":{\"type\":\"integer\",\"title\":\"Node cancellation polling interval (milliseconds)\",\"description\":\"The amount of milliseconds to wait between two checking of whether the node execution has been canceled.<p><strong>Valid range:</strong> [100, 5000]</p>\"},\"knime-db-connection-metadata-query-flatten\":{\"type\":\"boolean\",\"title\":\"Flatten sub-queries where possible\",\"description\":\"Enables or disables sub-query flattening where possible.\"},\"knime-db-connection-metadata-table-types\":{\"type\":\"string\",\"title\":\"List of table types to show in metadata browser\",\"description\":\"Comma separated list of table types to show in metadata browser.\"},\"knime-db-connection-metadata-configure-enabled\":{\"type\":\"boolean\",\"title\":\"Retrieve in configure\",\"description\":\"Enables or disables retrieving metadata in configure method for database nodes.\"},\"knime-db-connection-metadata-configure-timeout\":{\"type\":\"integer\",\"title\":\"Retrieve in configure timeout (seconds)\",\"description\":\"Time interval in seconds to wait before canceling a metadata retrieval in configure method.<p><strong>Valid range:</strong> [1,)</p>\"},\"knime-db-agent-writer-fail_on_missing_in_where_clause\":{\"type\":\"boolean\",\"title\":\"Fail if WHERE clause contains any missing value\",\"description\":\"Check every value of a WHERE clause (e.g., update, delete or merge) and fail if one is missing.\"},\"knime-db-connection-jdbc-fetch_size\":{\"type\":\"integer\",\"title\":\"Fetch size\",\"description\":\"Hint for the JDBC driver about the number of rows that should be fetched from the database when more rows are needed.<p><strong>Valid range:</strong> [0,)</p>\"},\"knime-db-capability-multi-dbs\":{\"type\":\"boolean\",\"title\":\"Support multiple databases\",\"description\":\"Enables or disables support for multiple databases in a single statement.\"}}}",
        "uiSchema" : "{\"type\":\"VerticalLayout\",\"elements\":[{\"type\":\"Section\",\"label\":\"Connection\",\"elements\":[{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-idle-timeout\"},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-reconnect\",\"options\":{\"format\":\"checkbox\"}},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-reconnect-timeout\"},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-restore\",\"options\":{\"format\":\"checkbox\"}},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-validation_query\"}]},{\"type\":\"Section\",\"label\":\"Dialect syntax\",\"elements\":[{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-dialect-sql-identifier-delimiting-onlyspaces\",\"options\":{\"format\":\"checkbox\"}},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-dialect-sql-delimiter-identifier-closing\"},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-dialect-sql-delimiter-identifier-opening\"},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-dialect-sql-identifier-replace-character-non_word-replacement\"},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-dialect-sql-identifier-replace-character-non_word-enabled\",\"options\":{\"format\":\"checkbox\"}}]},{\"type\":\"Section\",\"label\":\"JDBC logger\",\"elements\":[{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-logger-enabled\",\"options\":{\"format\":\"checkbox\"}}]},{\"type\":\"Section\",\"label\":\"JDBC statement cancellation\",\"elements\":[{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-statement-cancellation-enabled\",\"options\":{\"format\":\"checkbox\"}},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-statement-cancellation-polling_period\"}]},{\"type\":\"Section\",\"label\":\"Metadata\",\"elements\":[{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-metadata-query-flatten\",\"options\":{\"format\":\"checkbox\"}},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-metadata-table-types\"},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-metadata-configure-enabled\",\"options\":{\"format\":\"checkbox\"}},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-metadata-configure-timeout\"}]},{\"type\":\"Section\",\"label\":\"Other\",\"elements\":[{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-agent-writer-fail_on_missing_in_where_clause\",\"options\":{\"format\":\"checkbox\"}},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-connection-jdbc-fetch_size\"},{\"type\":\"Control\",\"scope\":\"#/properties/knime-db-capability-multi-dbs\",\"options\":{\"format\":\"checkbox\"}}]}]}",
        "persist" : null,
        "updates" : null,
        "settingsId" : null
      }
    } ]
  }, {
