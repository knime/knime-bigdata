                "fromType" : "{\"name\":\"serialized_data_type_settings\",\"value\":{\"dataType\":{\"type\":\"tree\",\"value\":{\"cell_class\":{\"type\":\"string\",\"value\":\"org.knime.core.data.time.localdatetime.LocalDateTimeCell\"},\"is_null\":{\"type\":\"boolean\",\"value\":false}}}}}",
                "toType" : "org.knime.core.data.convert.java.SimpleDataCellToJavaConverterFactory(LocalDateTimeValue,class java.time.LocalDateTime,LocalDateTime);java.time.LocalDateTime->TIMESTAMP"
              }, {
                "fromType" : "{\"name\":\"serialized_data_type_settings\",\"value\":{\"dataType\":{\"type\":\"tree\",\"value\":{\"cell_class\":{\"type\":\"string\",\"value\":\"org.knime.core.data.time.localtime.LocalTimeCell\"},\"is_null\":{\"type\":\"boolean\",\"value\":false}}}}}",
                "toType" : "org.knime.core.data.convert.java.SimpleDataCellToJavaConverterFactory(DataValue,class java.lang.String,String (toString()));java.lang.String->VARCHAR"
              }, {
                "fromType" : "{\"name\":\"serialized_data_type_settings\",\"value\":{\"dataType\":{\"type\":\"tree\",\"value\":{\"cell_class\":{\"type\":\"string\",\"value\":\"org.knime.core.data.time.period.PeriodCell\"},\"is_null\":{\"type\":\"boolean\",\"value\":false}}}}}",
                "toType" : "org.knime.core.data.convert.java.SimpleDataCellToJavaConverterFactory(DataValue,class java.lang.String,String (toString()));java.lang.String->VARCHAR"
              }, {
                "fromType" : "{\"name\":\"serialized_data_type_settings\",\"value\":{\"dataType\":{\"type\":\"tree\",\"value\":{\"cell_class\":{\"type\":\"string\",\"value\":\"org.knime.core.data.time.zoneddatetime.ZonedDateTimeCell\"},\"is_null\":{\"type\":\"boolean\",\"value\":false}}}}}",
                "toType" : "org.knime.core.data.convert.java.SimpleDataCellToJavaConverterFactory(DataValue,class java.lang.String,String (toString()));java.lang.String->VARCHAR"
              } ]
            }
          },
          "terminateClusterOnDisconnect" : {
            "type" : "boolean",
            "title" : "Terminate compute cluster on disconnect",
            "description" : "If selected, the compute cluster will be terminated when the KNIME workflow is closed or the node is reset. This can help reduce costs by ensuring that clusters are not left running when they are no longer needed.",
            "default" : false
          },
          "useLatestDriver" : {
            "type" : "boolean",
            "title" : "Use latest driver version available",
            "description" : "If selected, upon execution the node will automatically use the driver with the latest (highest) driver version that is available for the current database type. This has the advantage that you do not need to touch the workflow after a driver update. However, the workflow might break in the rare case that the behavior of the driver e.g. type mapping changes with the newer version.\n",
            "default" : true
          }
        }
      }
    }
  },
  "ui_schema" : {
    "elements" : [ {
      "label" : "Configuration",
      "type" : "Section",
      "elements" : [ {
        "type" : "Control",
        "scope" : "#/properties/model/properties/dbDialect",
        "options" : {
          "format" : "dropDown"
        },
        "providedOptions" : [ "possibleValues" ]
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/useLatestDriver",
        "options" : {
          "format" : "checkbox"
        }
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/dbDriver",
        "options" : {
          "format" : "dropDown"
        },
        "providedOptions" : [ "possibleValues" ],
        "rule" : {
          "effect" : "HIDE",
          "condition" : {
            "scope" : "#/properties/model/properties/useLatestDriver",
            "schema" : {
              "const" : true
            }
          }
        }
      } ]
    }, {
      "label" : "Connection",
      "type" : "Section",
      "elements" : [ {
        "type" : "Control",
        "scope" : "#/properties/model/properties/clusterId",
        "options" : {
          "format" : "dropDown"
        },
        "providedOptions" : [ "possibleValues" ]
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/terminateClusterOnDisconnect",
        "options" : {
          "format" : "checkbox"
        }
      } ]
    }, {
      "label" : "JDBC Parameters",
      "type" : "Section",
      "elements" : [ {
        "type" : "Control",
        "scope" : "#/properties/model/properties/jdbcParameters",
        "options" : {
          "detail" : [ {
            "type" : "Control",
            "scope" : "#/properties/propertyName"
          }, {
            "type" : "Control",
            "scope" : "#/properties/propertyType"
          }, {
            "type" : "Control",
            "scope" : "#/properties/value",
            "rule" : {
              "effect" : "SHOW",
              "condition" : {
                "scope" : "#/properties/propertyType",
                "schema" : {
                  "oneOf" : [ {
                    "const" : "STRING_OR_NUMBER"
                  } ]
                }
              }
            }
          }, {
            "type" : "Control",
            "scope" : "#/properties/username",
            "options" : {
              "hasPassword" : false,
              "usernameLabel" : "Username",
              "format" : "credentials"
            },
            "rule" : {
              "effect" : "SHOW",
              "condition" : {
                "scope" : "#/properties/propertyType",
                "schema" : {
                  "oneOf" : [ {
                    "const" : "USERNAME"
                  } ]
                }
              }
            }
          }, {
            "type" : "Control",
            "scope" : "#/properties/password",
            "options" : {
              "hasUsername" : false,
              "passwordLabel" : "Password",
              "format" : "credentials"
            },
            "rule" : {
              "effect" : "SHOW",
              "condition" : {
                "scope" : "#/properties/propertyType",
                "schema" : {
                  "oneOf" : [ {
                    "const" : "PASSWORD"
                  } ]
                }
              }
            }
          }, {
            "type" : "Control",
            "scope" : "#/properties/file",
            "options" : {
              "isLocal" : true,
              "spaceFSOptions" : {
                "mountId" : "Local space"
              },
              "format" : "fileChooser"
            },
            "rule" : {
              "effect" : "SHOW",
              "condition" : {
                "scope" : "#/properties/propertyType",
                "schema" : {
                  "oneOf" : [ {
                    "const" : "FILE_PATH"
                  }, {
                    "const" : "FILE_URL"
                  } ]
                }
              }
            }
          } ],
          "addButtonText" : "Add parameter",
          "arrayElementTitle" : "Parameter"
        }
      } ]
    }, {
      "label" : "Input Type Mapping",
      "type" : "SettingsSubPanelLayout",
      "options" : {
        "isAdvanced" : true
      },
      "elements" : [ {
        "label" : "Input mapping by name",
        "type" : "Section",
        "elements" : [ {
          "type" : "Control",
          "scope" : "#/properties/model/properties/inputMapping/properties/byNameSettings",
          "options" : {
            "detail" : [ {
              "type" : "Control",
              "scope" : "#/properties/filterType",
              "options" : {
                "format" : "valueSwitch"
              }
            }, {
              "type" : "Control",
              "scope" : "#/properties/fromColName"
            }, {
              "type" : "Control",
              "scope" : "#/properties/fromColType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues" ]
            }, {
              "type" : "Control",
              "scope" : "#/properties/toColType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues" ]
            } ],
            "addButtonText" : "Add name",
            "arrayElementTitle" : "Column name"
          }
        } ]
      }, {
        "label" : "Input mapping by type",
        "type" : "Section",
        "elements" : [ {
          "type" : "Control",
          "scope" : "#/properties/model/properties/inputMapping/properties/byTypeSettings",
          "options" : {
            "detail" : [ {
              "type" : "Control",
              "scope" : "#/properties/fromType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues" ]
            }, {
              "type" : "Control",
              "scope" : "#/properties/toType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues" ]
            } ],
            "addButtonText" : "Add type",
            "arrayElementTitle" : "Type"
          }
        } ]
      } ]
    }, {
      "label" : "Output Type Mapping",
      "type" : "SettingsSubPanelLayout",
      "options" : {
        "isAdvanced" : true
      },
      "elements" : [ {
        "label" : "Output mapping by name",
        "type" : "Section",
        "elements" : [ {
          "type" : "Control",
          "scope" : "#/properties/model/properties/outputMapping/properties/byNameSettings",
          "options" : {
            "detail" : [ {
              "type" : "Control",
              "scope" : "#/properties/filterType",
              "options" : {
                "format" : "valueSwitch"
              }
            }, {
              "type" : "Control",
              "scope" : "#/properties/fromColName"
            }, {
              "type" : "Control",
              "scope" : "#/properties/fromColType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues", "possibleValues" ]
            }, {
              "type" : "Control",
              "scope" : "#/properties/toColType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues" ]
            } ],
            "addButtonText" : "Add name",
            "arrayElementTitle" : "Column name"
          }
        } ]
      }, {
        "label" : "Output mapping by type",
        "type" : "Section",
        "elements" : [ {
          "type" : "Control",
          "scope" : "#/properties/model/properties/outputMapping/properties/byTypeSettings",
          "options" : {
            "detail" : [ {
              "type" : "Control",
              "scope" : "#/properties/fromType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues", "possibleValues" ]
            }, {
              "type" : "Control",
              "scope" : "#/properties/toType",
              "options" : {
                "format" : "dropDown"
              },
              "providedOptions" : [ "possibleValues" ]
            } ],
            "addButtonText" : "Add type",
            "arrayElementTitle" : "Type"
          }
        } ]
      } ]
    }, {
      "label" : "Additional Settings",
      "type" : "SettingsSubPanelLayout",
      "options" : {
        "isAdvanced" : true
      },
      "elements" : [ {
        "type" : "Control",
        "scope" : "#/properties/model/properties/additionalSettings/properties/attributes",
        "options" : {
          "format" : "dynamicInput"
        },
        "providedOptions" : [ "dynamicSettings" ]
      } ]
    } ]
  },
