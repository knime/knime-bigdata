<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="http://www.knime.org/2008/09/XMLConfig" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.knime.org/2008/09/XMLConfig http://www.knime.org/XMLConfig_2008_09.xsd" key="test">
    <entry key="url" type="xstring" value="https://some-host"/>
    <config key="auth">
        <entry key="type" type="xstring" value="token"/>
        <config key="user_pwd">
            <entry key="user" type="xstring" value="sascha"/>
            <entry key="password" type="xpassword" value=""/>
            <entry key="use_credentials" type="xboolean" value="false"/>
            <entry key="credentials" type="xstring" value=""/>
        </config>
        <config key="token">
            <entry key="secret" type="xpassword" value="02CgAAAGMq_QxveL1vZ0EBj0NoTyct_VCRVJqmvndL"/>
            <entry key="use_credentials" type="xboolean" value="false"/>
            <entry key="credentials" type="xstring" value=""/>
        </config>
    </config>
    <entry key="workingDirectory" type="xstring" value="/some/dir"/>
    <entry key="connectionTimeout" type="xint" value="30"/>
    <entry key="readTimeout" type="xint" value="30"/>
</config>
